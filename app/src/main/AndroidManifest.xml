<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- Allow the in-app updater to launch the APK installer for downloaded releases. -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:name=".StoresApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Stores"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">

        <activity
            android:name=".ui.login.LoginActivity"
            android:exported="true"
            android:theme="@style/Theme.Stores.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.dashboard.DashboardActivity"
            android:launchMode="singleTop"
            android:theme="@style/Theme.Stores.NoActionBar" />

        <activity
            android:name=".ui.settings.SettingsActivity"
            android:launchMode="singleTop"
            android:theme="@style/Theme.Stores.NoActionBar" />

        <activity
            android:name=".ui.grn.GrnListActivity"
            android:launchMode="singleTop"
            android:theme="@style/Theme.Stores.NoActionBar" />

        <activity
            android:name=".ui.inventory.InventoryActivity"
            android:launchMode="singleTop"
            android:theme="@style/Theme.Stores.NoActionBar" />

        <activity
            android:name=".ui.history.HistoryActivity"
            android:launchMode="singleTop"
            android:theme="@style/Theme.Stores.NoActionBar" />

        <activity
            android:name=".ui.history.HistoryHubActivity"
            android:launchMode="singleTop"
            android:theme="@style/Theme.Stores.NoActionBar" />

        <activity
            android:name=".ui.grn.GrnDetailActivity"
            android:theme="@style/Theme.Stores.NoActionBar" />

        <activity
            android:name=".ui.grn.GrnCreateActivity"
            android:theme="@style/Theme.Stores.NoActionBar" />

        <activity
            android:name=".ui.verification.VerificationListActivity"
            android:launchMode="singleTop"
            android:theme="@style/Theme.Stores.NoActionBar" />

        <activity
            android:name=".ui.verification.VerificationDetailActivity"
            android:theme="@style/Theme.Stores.NoActionBar" />

        <activity
            android:name=".ui.verification.VerificationCreateActivity"
            android:theme="@style/Theme.Stores.NoActionBar" />

        <activity
            android:name=".ui.issue.IssueListActivity"
            android:launchMode="singleTop"
            android:theme="@style/Theme.Stores.NoActionBar" />

        <activity
            android:name=".ui.issue.IssueDetailActivity"
            android:theme="@style/Theme.Stores.NoActionBar" />

        <activity
            android:name=".ui.issue.IssueCreateActivity"
            android:theme="@style/Theme.Stores.NoActionBar" />

        <activity
            android:name=".ui.transfer.TransferListActivity"
            android:launchMode="singleTop"
            android:theme="@style/Theme.Stores.NoActionBar" />

        <activity
            android:name=".ui.transfer.TransferDetailActivity"
            android:theme="@style/Theme.Stores.NoActionBar" />

        <activity
            android:name=".ui.transfer.TransferCreateActivity"
            android:theme="@style/Theme.Stores.NoActionBar" />

        <activity
            android:name=".ui.ret.ReturnListActivity"
            android:launchMode="singleTop"
            android:theme="@style/Theme.Stores.NoActionBar" />

        <activity
            android:name=".ui.ret.ReturnDetailActivity"
            android:theme="@style/Theme.Stores.NoActionBar" />

        <activity
            android:name=".ui.ret.ReturnCreateActivity"
            android:theme="@style/Theme.Stores.NoActionBar" />

        <activity
            android:name=".ui.adjustment.AdjustmentListActivity"
            android:launchMode="singleTop"
            android:theme="@style/Theme.Stores.NoActionBar" />

        <activity
            android:name=".ui.adjustment.AdjustmentDetailActivity"
            android:theme="@style/Theme.Stores.NoActionBar" />

        <activity
            android:name=".ui.adjustment.AdjustmentCreateActivity"
            android:theme="@style/Theme.Stores.NoActionBar" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
