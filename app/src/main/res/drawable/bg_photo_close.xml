<?xml version="1.0" encoding="utf-8"?>
<!-- Dark semi-transparent circle, used as the background for photo
     overlay controls (× remove button, +N count badge) so the white
     foreground (icon/text) stays visible over any photo. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <solid android:color="#CC000000" />
</shape>
